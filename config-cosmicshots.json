{
  "niche": "cosmicshots",
  "python": "venv/bin/python",
  "notifications": {
    "on_failure": true,
    "consecutive_failures_alert": 3
  },
  "scripts": {
    "post": {
      "type": "scheduled",
      "file": "post.py",
      "times_et": [
        "10:30",
        "20:00"
      ],
      "jitter_minutes": 45,
      "enabled": true,
      "timeout_seconds": 300,
      "limits": {},
      "extra_args": []
    },
    "engage": {
      "type": "scheduled",
      "file": "engage.py",
      "times_et": [
        "11:00",
        "16:00",
        "20:00"
      ],
      "jitter_minutes": 15,
      "enabled": false,
      "timeout_seconds": 1200,
      "limits": {
        "--max-likes": 5,
        "--max-replies": 5,
        "--max-follows": 2
      }
    },
    "respond": {
      "type": "scheduled",
      "file": "respond.py",
      "times_et": [
        "12:00",
        "18:00"
      ],
      "jitter_minutes": 15,
      "enabled": false,
      "timeout_seconds": 600,
      "limits": {
        "--max-responses": 5
      }
    },
    "track_performance": {
      "enabled": true,
      "file": "track_performance.py",
      "type": "scheduled",
      "times_et": [
        "06:00",
        "18:00"
      ],
      "jitter_minutes": 15,
      "timeout_seconds": 120,
      "extra_args": []
    },
    "learn": {
      "enabled": true,
      "file": "learn.py",
      "type": "scheduled",
      "times_et": [
        "05:00"
      ],
      "jitter_minutes": 30,
      "timeout_seconds": 300,
      "extra_args": []
    },
    "healthcheck": {
      "type": "scheduled",
      "file": "healthcheck.py",
      "times_et": [
        "06:00"
      ],
      "jitter_minutes": 5,
      "enabled": true,
      "timeout_seconds": 60,
      "extra_args": [
        "--fix"
      ]
    },
    "nasa_fetch": {
      "type": "scheduled",
      "file": "nasa_fetch.py",
      "times_et": [
        "08:00"
      ],
      "jitter_minutes": 30,
      "enabled": true,
      "timeout_seconds": 900,
      "extra_args": [
        "--batch-size",
        "4"
      ]
    }
  },
  "models": {
    "writer": "claude-opus-4-6",
    "rewrite": "claude-opus-4-6",
    "vision": "claude-opus-4-6",
    "reply_drafter": "claude-opus-4-6",
    "evaluator": "claude-haiku-4-5-20251001",
    "scorer": "claude-haiku-4-5-20251001",
    "fact_extract": "claude-haiku-4-5-20251001",
    "fact_research": "claude-haiku-4-5-20251001",
    "fact_qa": "claude-haiku-4-5-20251001",
    "chat": "claude-sonnet-4-6",
    "quote_writer": "claude-sonnet-4-6",
    "enrich_vision": "claude-sonnet-4-6"
  },
  "delays": {
    "engage": [
      60,
      240
    ],
    "respond": [
      30,
      90
    ]
  },
  "max_queries_per_run": 3,
  "posting_window": {
    "start_hour_et": 9,
    "end_hour_et": 22,
    "max_per_day": 2,
    "min_gap_hours": 3,
    "min_post_score": 7,
    "low_queue_threshold": 5,
    "min_image_dimension": 800
  }
}